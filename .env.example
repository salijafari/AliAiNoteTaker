# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Anthropic API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Your Telegram user ID — this account is the master admin and can never be removed.
# To find your ID: message @userinfobot on Telegram, it replies instantly with your numeric ID.
ADMIN_USER_ID=123456789

# Optional: override the SQLite database path (defaults to /data/bot_data.db on Railway)
# DB_PATH=/data/bot_data.db
